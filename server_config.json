{
    "mcpServers": [
        {
            "name": "filesystem",
            "description": "A filesystem server",
            "type": "stdio",
            "config": {
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-filesystem",
                    "."
                ]
            }
        },
        {
            "name": "research",
            "description": "A research server",
            "type": "sse",
            "config": {
                "url": "https://remote-research-dovn.onrender.com/sse"
            }
        },
        {
            "name": "fetch",
            "description": "A fetch server",
            "type": "stdio",
            "config": {
                "command": "uvx",
                "args": ["mcp-server-fetch"]
            }
        }
    ]
}
  